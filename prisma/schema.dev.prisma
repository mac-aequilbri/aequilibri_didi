// â”€â”€ Memory architecture / learning loop (UC1) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Episodic: Job + Correction. Hypothesis â†’ LearningRule promotion.
// Contextual Intelligence snapshot. See aequilibri Memory Architecture doc.

model Uc1Job {
  id                    Int       @id @default(autoincrement())
  quoteId               Int?      @map("quote_id")
  address               String    @default("")
  estimatorId           Int?      @map("estimator_id")
  sessionOpenAt         DateTime? @map("session_open_at")
  sessionCloseAt        DateTime? @map("session_close_at")
  // AI estimates (set at session close)
  estimatedAreaM2       Float     @default(0) @map("estimated_area_m2")
  estimatedValleyLm     Float     @default(0) @map("estimated_valley_lm")
  estimatedRidgeLm      Float     @default(0) @map("estimated_ridge_lm")
  estimatedEaveLm       Float     @default(0) @map("estimated_eave_lm")
  estimatedHipLm        Float     @default(0) @map("estimated_hip_lm")
  estimatedTotal        Float   @default(0) @map("estimated_total")
  // Actual outcomes (set when job invoiced)
  actualAreaM2          Float?    @map("actual_area_m2")
  actualValleyLm        Float?    @map("actual_valley_lm")
  actualRidgeLm         Float?    @map("actual_ridge_lm")
  actualEaveLm          Float?    @map("actual_eave_lm")
  actualHipLm           Float?    @map("actual_hip_lm")
  actualTotal           Float?  @map("actual_total")
  // Derived
  variancePctArea       Float?    @map("variance_pct_area")
  variancePctQuote      Float?    @map("variance_pct_quote")
  learningRuleCandidate Boolean   @default(false) @map("learning_rule_candidate")
  rulesAppliedJson      String    @default("[]") @map("rules_applied_json") // codes of rules applied
  status                String    @default("open") // open | estimated | completed | invoiced
  notes                 String    @default("")
  createdAt             DateTime  @default(now()) @map("created_at")
  completedAt           DateTime? @map("completed_at")

  estimator   Uc1TeamMember? @relation(fields: [estimatorId], references: [id], onDelete: SetNull)
  corrections Uc1Correction[]

  @@index([createdAt])
  @@map("uc1_roofing_job")
}

model Uc1Correction {
  id           Int       @id @default(autoincrement())
  jobId        Int?      @map("job_id")
  quoteId      Int?      @map("quote_id")
  address      String    @default("")
  suburb       String    @default("")
  lat          Float?
  lng          Float?
  dimension    String // roof_area | valley_lm | ridge_lm | pitch | contingency ...
  aiValue      Float     @default(0) @map("ai_value")
  humanValue   Float     @default(0) @map("human_value")
  variancePct  Float     @default(0) @map("variance_pct")
  rootCause    String    @default("") @map("root_cause") // REQUIRED â€” never blank
  estimatorId  Int?      @map("estimator_id")
  hypothesisId Int?      @map("hypothesis_id")
  ruleId       Int?      @map("rule_id") // set if this correction led to a rule
  createdAt    DateTime  @default(now()) @map("created_at")

  job        Uc1Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  estimator  Uc1TeamMember?  @relation(fields: [estimatorId], references: [id], onDelete: SetNull)
  hypothesis Uc1Hypothesis?  @relation(fields: [hypothesisId], references: [id], onDelete: SetNull)

  @@index([dimension, createdAt])
  @@map("uc1_roofing_correction")
}

model Uc1Hypothesis {
  id               Int      @id @default(autoincrement())
  description      String
  dimension        String
  rootCausePattern String   @default("") @map("root_cause_pattern")
  triggerCondition String   @default("") @map("trigger_condition")
  sampleCount      Int      @default(0) @map("sample_count")
  avgVariancePct   Float    @default(0) @map("avg_variance_pct")
  confidence       Int      @default(0) // 0-100
  status           String   @default("pending") // pending | active | validated | rejected | promoted
  promoteToRule    Boolean  @default(false) @map("promote_to_rule")
  createdAt        DateTime @default(now()) @map("created_at")
  reviewedAt       DateTime? @map("reviewed_at")

  corrections Uc1Correction[]
  rules       Uc1LearningRule[]

  @@map("uc1_roofing_hypothesis")
}

model Uc1LearningRule {
  id               Int       @id @default(autoincrement())
  ruleCode         String    @unique @map("rule_code")
  description      String
  category         String    @default("measurement") // measurement | pricing | scope | regional | equipment
  dimension        String
  triggerCondition String    @default("") @map("trigger_condition")
  adjustment       String    @default("{}") // JSON: { type, value }
  priority         Int       @default(3)
  confidence       Int       @default(72)
  timesTriggered   Int       @default(0) @map("times_triggered")
  isActive         Boolean   @default(true) @map("is_active")
  autoApply        Boolean   @default(false) @map("auto_apply")
  sourceId         Int?      @map("source_id")
  taughtById       Int?      @map("taught_by_id")
  dateActivated    DateTime? @map("date_activated")
  notes            String    @default("")
  createdAt        DateTime  @default(now()) @map("created_at")

  source    Uc1Hypothesis?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  taughtBy  Uc1TeamMember?  @relation(fields: [taughtById], references: [id], onDelete: SetNull)

  @@map("uc1_roofing_learningrule")
}

model Uc1IntelligenceSnapshot {
  id                   Int      @id @default(autoincrement())
  capturedAt           DateTime @default(now()) @map("captured_at")
  totalJobs            Int      @default(0) @map("total_jobs")
  completedJobs        Int      @default(0) @map("completed_jobs")
  accuracyRatePct      Float    @default(0) @map("accuracy_rate_pct")
  activeRules          Int      @default(0) @map("active_rules")
  autoApplyRules       Int      @default(0) @map("auto_apply_rules")
  avgConfidence        Float    @default(0) @map("avg_confidence")
  confidenceTrajectory String   @default("stable") @map("confidence_trajectory") // improving | stable | degrading
  topRulesJson         String   @default("[]") @map("top_rules_json")
  gapsJson             String   @default("[]") @map("gaps_json")
  notes                String   @default("")

  @@map("uc1_roofing_intelligencesnapshot")
}

