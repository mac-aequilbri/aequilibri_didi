model PlatConPhase {
  id            Int       @id @default(autoincrement())
  orgId         Int       @map("org_id")
  jobId         Int       @map("job_id")
  name          String
  status        String    @default("pending")
  completionPct Int       @default(0) @map("completion_pct")
  sortOrder     Int       @default(0) @map("sort_order")
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  isAiDraft     Boolean   @default(false) @map("is_ai_draft")
  approvedBy    String    @default("") @map("approved_by")
  // AI-suggested completion from site evidence (JSON annotation). Never
  // applied to completionPct directly — a human approves/adjusts/dismisses.
  evidenceSuggestion String @default("{}") @map("evidence_suggestion")
  createdAt     DateTime  @default(now()) @map("created_at")

  org         PlatOrganisation    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job         PlatJob             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  budgetLines PlatConBudgetLine[]
  evidence    PlatConPhaseEvidence[]

  @@index([jobId, sortOrder])
  @@map("plat_con_phase")
}

// Site evidence (photos, documents, videos) attached to a phase — the inputs
// the evidence-review AI reads when suggesting a completion percentage.
model PlatConPhaseEvidence {
  id         Int      @id @default(autoincrement())
  orgId      Int      @map("org_id")
  jobId      Int      @map("job_id")
  phaseId    Int      @map("phase_id")
  documentId Int      @map("document_id")
  note       String   @default("")
  addedBy    String   @default("") @map("added_by")
  createdAt  DateTime @default(now()) @map("created_at")

  org      PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job      PlatJob          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  phase    PlatConPhase     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  document PlatDocument     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([phaseId, documentId])
  @@index([jobId])
  @@map("plat_con_phaseevidence")
}

