  id        Int     @id @default(autoincrement())
  projectId Int     @map("project_id")
  tenantId  Int     @map("tenant_id")
  period    String
  projected Float @default(0)
  actual    Float @default(0)

  project Uc3Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant  Uc3Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("uc3_msme_cashflow")
}

model Uc3TenantUser {
  id         Int      @id @default(autoincrement())
  tenantId   Int      @map("tenant_id")
  email      String
  name       String
  role       String   @default("readonly")
  mfaEnabled Boolean  @default(false) @map("mfa_enabled")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Uc3Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@map("uc3_msme_tenantuser")
}

model Uc3ExecutionLog {
  id          Int      @id @default(autoincrement())
  tenantId    Int?     @map("tenant_id")
  projectId   Int?     @map("project_id")
  toolName    String   @map("tool_name")
  payload     String
  result      String
  status      String   @default("success")
  aiAuthority String   @default("") @map("ai_authority")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant  Uc3Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Uc3Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("uc3_msme_executionlog")
}

model Uc3ChatMessage {
