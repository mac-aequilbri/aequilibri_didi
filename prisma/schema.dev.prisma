// =====================================================================
// PLATFORM â€” three-tier architecture (Platform Architecture doc, June 2026)
// Core tier (plat_core_*):   identical schema for every customer instance.
// Domain tier (plat_con_*):  construction vertical extension.
// Config tier (plat_cfg_*):  customer-specific configuration.
// JSON payloads are String columns (app JSON-encodes) so the SQLite dev
// schema generator keeps working; money is Decimal as elsewhere.
// =====================================================================

// â”€â”€ Core tier â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model PlatOrganisation {
  id                     Int      @id @default(autoincrement())
  slug                   String   @unique
  name                   String
  vertical               String   @default("construction")
  defaultEngagementType  String   @default("long_project") @map("default_engagement_type")
  allowedEngagementTypes String   @default("[]") @map("allowed_engagement_types")
  aiAuthority            String   @default("approve_required") @map("ai_authority")
  settings               String   @default("{}")
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at")

  contacts        PlatContact[]
  jobs            PlatJob[]
  workstreams     PlatWorkstream[]
  actions         PlatActionHub[]
  decisions       PlatDecision[]
  learningRules   PlatLearningRule[]
  hypotheses      PlatHypothesis[]
  corrections     PlatCorrection[]
  execLogs        PlatExecutionLog[]
  documents       PlatDocument[]
  snapshots       PlatIntelligenceSnapshot[]
  chatSessions    PlatChatSession[]
  chatMessages    PlatChatMessage[]
  conPhases       PlatConPhase[]
  conBudgetLines  PlatConBudgetLine[]
  conCashflows    PlatConCashflow[]
  conRisks        PlatConRisk[]
  conVariations   PlatConVariationOrder[]
  conVendors      PlatConVendor[]
  conProcurement  PlatConProcurement[]
  conRooms        PlatConRoomMatrix[]
  conMinutes      PlatConMeetingMinutes[]
  conReports      PlatConWeeklyReport[]
  conBimModels    PlatConBimModel[]
  conPortalTokens PlatConPortalToken[]
  conPhaseEvidence PlatConPhaseEvidence[]
  conAccounting   PlatConAccountingConnection[]
  cfgTeam         PlatCfgTeamMember[]
  cfgRegions      PlatCfgRegion[]
  cfgReferences   PlatCfgReference[]
  cfgNomenclature PlatCfgNomenclature[]
  cfgSettings     PlatCfgSetting[]
  pendingWrites   PlatPendingWrite[]
  assessments     PlatAssessment[]

  @@map("plat_core_organisation")
}

// Approval queue for deferred AI writes — split out of PlatExecutionLog so
// the execution log stays an append-only audit trail while proposals carry
// mutable workflow state (status, resolution, expiry).
model PlatPendingWrite {
  id              Int       @id @default(autoincrement())
  orgId           Int       @map("org_id")
  jobId           Int?      @map("job_id")
  tableKey        String    @map("table_key")
  op              String
  recordId        Int?      @map("record_id")
  payload         String    @default("{}")
  actorType       String    @default("ai") @map("actor_type")
  actorName       String    @default("") @map("actor_name")
  sourceMessageId Int?      @map("source_message_id")
  status          String    @default("proposed")
  resolvedBy      String    @default("") @map("resolved_by")
  resolvedAt      DateTime? @map("resolved_at")
  execLogId       Int?      @map("exec_log_id")
  error           String    @default("")
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@map("plat_core_pendingwrite")
}

// Assessment Engine results as first-class records (previously crammed into
// the execution log's text column).
model PlatAssessment {
  id             Int      @id @default(autoincrement())
  orgId          Int      @map("org_id")
  name           String
  engagementType String   @default("long_project") @map("engagement_type")
  address        String   @default("")
  suburb         String   @default("")
  sizeSqm        Float?   @map("size_sqm")
  scope          String   @default("")
  result         String   @default("{}")
  status         String   @default("draft")
  jobId          Int?     @map("job_id")
  promptVersion  String   @default("") @map("prompt_version")
  createdBy      String   @default("") @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  org PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@map("plat_core_assessment")
}

model PlatContact {
  id        Int      @id @default(autoincrement())
  orgId     Int      @map("org_id")
  name      String
  type      String   @default("client") @map("contact_type")
  role      String   @default("")
  email     String   @default("")
  phone     String   @default("")
  company   String   @default("")
  notes     String   @default("")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  org  PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobs PlatJob[]

  @@index([orgId, isActive])
  @@map("plat_core_contact")
}

model PlatJob {
  id              Int       @id @default(autoincrement())
  orgId           Int       @map("org_id")
  code            String
  name            String
  engagementType  String    @default("long_project") @map("engagement_type")
  status          String    @default("intake")
  clientContactId Int?      @map("client_contact_id")
  address         String    @default("")
  suburb          String    @default("")
  lat             Float?
  lng             Float?
  startDate       DateTime? @map("start_date")
  targetEndDate   DateTime? @map("target_end_date")
  completionPct   Int       @default(0) @map("completion_pct")
  healthScore     Int       @default(50) @map("health_score")
  budgetTotal     Float   @default(0) @map("budget_total")
  summary         String    @default("")
  meta            String    @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  org           PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  clientContact PlatContact?     @relation(fields: [clientContactId], references: [id], onDelete: SetNull)

  workstreams     PlatWorkstream[]
  actions         PlatActionHub[]
  decisions       PlatDecision[]
  corrections     PlatCorrection[]
  execLogs        PlatExecutionLog[]
  documents       PlatDocument[]
  chatSessions    PlatChatSession[]
  conPhases       PlatConPhase[]
  conBudgets      PlatConBudgetLine[]
  conCashflows    PlatConCashflow[]
  conRisks        PlatConRisk[]
  conVariations   PlatConVariationOrder[]
  conProcurement  PlatConProcurement[]
  conRooms        PlatConRoomMatrix[]
  conMinutes      PlatConMeetingMinutes[]
  conReports      PlatConWeeklyReport[]
  conBimModels    PlatConBimModel[]
  conPortalTokens PlatConPortalToken[]
  conPhaseEvidence PlatConPhaseEvidence[]

  @@unique([orgId, code])
  @@index([orgId, status])
  @@map("plat_core_job")
}

model PlatWorkstream {
  id          Int      @id @default(autoincrement())
  orgId       Int      @map("org_id")
  jobId       Int?     @map("job_id")
  name        String
  description String   @default("")
  milestone   String   @default("")
  status      String   @default("active")
  notes       String   @default("")
  lastUpdated DateTime @updatedAt @map("last_updated")
  createdAt   DateTime @default(now()) @map("created_at")

  org     PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job     PlatJob?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  actions PlatActionHub[]

  @@index([orgId, status])
  @@map("plat_core_workstream")
}

model PlatActionHub {
  id           Int       @id @default(autoincrement())
  orgId        Int       @map("org_id")
  jobId        Int?      @map("job_id")
  workstreamId Int?      @map("workstream_id")
  title        String
  detail       String    @default("")
  priority     String    @default("P2")
  status       String    @default("open")
  owner        String    @default("")
  dueDate      DateTime? @map("due_date")
  sourceType   String    @default("manual") @map("source_type")
  sourceId     Int?      @map("source_id")
  context      String    @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  org        PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job        PlatJob?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  workstream PlatWorkstream?  @relation(fields: [workstreamId], references: [id], onDelete: SetNull)

  @@index([orgId, status, dueDate])
  @@map("plat_core_actionhub")
}

model PlatDecision {
  id           Int       @id @default(autoincrement())
  orgId        Int       @map("org_id")
  jobId        Int?      @map("job_id")
  description  String
  rationale    String    @default("")
  alternatives String    @default("")
  category     String    @default("")
  status       String    @default("proposed")
  madeBy       String    @default("") @map("made_by")
  sourceType   String    @default("manual") @map("source_type")
  sourceId     Int?      @map("source_id")
  decidedAt    DateTime? @map("decided_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  org PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job PlatJob?         @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@map("plat_core_decision")
}

model PlatLearningRule {
  id                 Int       @id @default(autoincrement())
  orgId              Int       @map("org_id")
  ruleCode           String    @map("rule_code")
  kind               String    @default("guidance")
  description        String
  category           String    @default("")
  dimension          String    @default("")
  triggerCondition   String    @default("{}") @map("trigger_condition")
  adjustment         String    @default("{}")
  priority           Int       @default(0)
  confidence         Int       @default(50)
  timesTriggered     Int       @default(0) @map("times_triggered")
  isActive           Boolean   @default(true) @map("is_active")
  autoApply          Boolean   @default(false) @map("auto_apply")
  cannotOverride     Boolean   @default(false) @map("cannot_override")
  sourceHypothesisId Int?      @map("source_hypothesis_id")
  notes              String    @default("")
  dateActivated      DateTime? @map("date_activated")
  createdAt          DateTime  @default(now()) @map("created_at")

  org              PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sourceHypothesis PlatHypothesis?  @relation(fields: [sourceHypothesisId], references: [id], onDelete: SetNull)
  corrections      PlatCorrection[]

  @@unique([orgId, ruleCode])
  @@index([orgId, isActive])
  @@map("plat_core_learningrule")
}

model PlatHypothesis {
  id               Int       @id @default(autoincrement())
  orgId            Int       @map("org_id")
  description      String
  dimension        String    @default("")
  rootCausePattern String    @default("") @map("root_cause_pattern")
  triggerCondition String    @default("{}") @map("trigger_condition")
  sampleCount      Int       @default(0) @map("sample_count")
  avgVariancePct   Float     @default(0) @map("avg_variance_pct")
  confidence       Int       @default(0)
  status           String    @default("pending")
  sourceType       String    @default("correction") @map("source_type")
  sourceId         Int?      @map("source_id")
  reviewedAt       DateTime? @map("reviewed_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  org           PlatOrganisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  promotedRules PlatLearningRule[]
  corrections   PlatCorrection[]

  @@index([orgId, status])
  @@map("plat_core_hypothesis")
}

model PlatCorrection {
  id             Int      @id @default(autoincrement())
  orgId          Int      @map("org_id")
  jobId          Int?     @map("job_id")
  entityType     String   @default("") @map("entity_type")
  entityId       Int?     @map("entity_id")
  dimension      String
  aiValue        Float?   @map("ai_value")
  humanValue     Float?   @map("human_value")
  aiValueText    String   @default("") @map("ai_value_text")
  humanValueText String   @default("") @map("human_value_text")
  variancePct    Float?   @map("variance_pct")
  rootCause      String   @map("root_cause")
  context        String   @default("{}")
  correctedBy    String   @default("") @map("corrected_by")
  hypothesisId   Int?     @map("hypothesis_id")
  ruleId         Int?     @map("rule_id")
  createdAt      DateTime @default(now()) @map("created_at")

  org        PlatOrganisation  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job        PlatJob?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  hypothesis PlatHypothesis?   @relation(fields: [hypothesisId], references: [id], onDelete: SetNull)
  rule       PlatLearningRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([orgId, dimension, createdAt])
  @@map("plat_core_correction")
}

model PlatExecutionLog {
  id              Int       @id @default(autoincrement())
  orgId           Int       @map("org_id")
  jobId           Int?      @map("job_id")
  actorType       String    @default("system") @map("actor_type")
  actorName       String    @default("") @map("actor_name")
  operation       String    @default("")
  targetTable     String    @default("") @map("target_table")
  targetId        Int?      @map("target_id")
  payload         String    @default("{}")
  result          String    @default("")
  status          String    @default("executed")
  sourceMessageId Int?      @map("source_message_id")
  approvedBy      String    @default("") @map("approved_by")
  executedAt      DateTime? @map("executed_at")
  error           String    @default("")
  promptVersion   String    @default("") @map("prompt_version")
  createdAt       DateTime  @default(now()) @map("created_at")

  org PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job PlatJob?         @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([orgId, status, createdAt])
  @@map("plat_core_executionlog")
}

model PlatDocument {
  id               Int       @id @default(autoincrement())
  orgId            Int       @map("org_id")
  jobId            Int?      @map("job_id")
  title            String
  kind             String    @default("file")
  docType          String    @default("") @map("doc_type")
  classification   String    @default("")
  storageProvider  String    @default("local") @map("storage_provider")
  storageRef       String    @default("") @map("storage_ref")
  mimeType         String    @default("") @map("mime_type")
  sizeBytes        Int       @default(0) @map("size_bytes")
  version          Int       @default(1)
  parentDocumentId Int?      @map("parent_document_id")
  textContent      String    @default("") @map("text_content")
  aiSummary        String    @default("") @map("ai_summary")
  aiAnalysis       String    @default("{}") @map("ai_analysis")
  confidence       Int?
  status           String    @default("uploaded")
  uploadedBy       String    @default("") @map("uploaded_by")
  analyzedAt       DateTime? @map("analyzed_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  org            PlatOrganisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job            PlatJob?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  parentDocument PlatDocument?    @relation("PlatDocumentVersions", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  versions       PlatDocument[]   @relation("PlatDocumentVersions")
  phaseEvidence  PlatConPhaseEvidence[]

  @@index([orgId, status])
  @@map("plat_core_document")
}

