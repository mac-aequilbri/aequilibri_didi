// ── Measurement memory (UC1) ─────────────────────────────────────────
// Structured roof-measurement snapshots captured during quote creation,
// the user-applied update events linked to them, and immutable quote-
// generation snapshots for later variance analysis. Ported from the
// Django MeasurementSnapshot / MeasurementUpdate / QuoteSnapshot models.

model Uc1MeasurementSnapshot {
  id              Int      @id @default(autoincrement())
  quoteId         Int?     @map("quote_id")
  snapshotType    String   @default("use_measurements") @map("snapshot_type")
  source          String   @default("")
  address         String   @default("")
  addressKey      String   @default("") @map("address_key")
  lat             Float?
  lng             Float?
  totalAreaM2     Float  @default(0) @map("total_area_m2")
  footprintAreaM2 Float  @default(0) @map("footprint_area_m2")
  pitchDeg        Float  @default(0) @map("pitch_deg")
  pitchFactor     Float  @default(1) @map("pitch_factor")
  eaveLm          Float  @default(0) @map("eave_lm")
  perimeterM      Float  @default(0) @map("perimeter_m")
  ridgeLm         Float  @default(0) @map("ridge_lm")
  valleyLm        Float  @default(0) @map("valley_lm")
  hipLm           Float  @default(0) @map("hip_lm")
  rakeLm          Float  @default(0) @map("rake_lm")
  storeys         Int      @default(1)
  material        String   @default("")
  roofColour      String   @default("") @map("roof_colour")
  sectionCount    Int      @default(0) @map("section_count")
  outlineVertices Int      @default(0) @map("outline_vertices")
  equipmentJson   String   @default("[]") @map("equipment_json")
  polygonJson     String   @default("[]") @map("polygon_json")
  sectionsJson    String   @default("[]") @map("sections_json")
  payloadJson     String   @default("{}") @map("payload_json")
  createdAt       DateTime @default(now()) @map("created_at")

  quote   Uc1Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  updates Uc1MeasurementUpdate[]
  quoteSnapshots Uc1QuoteSnapshot[]

  @@index([addressKey, createdAt])
  @@index([snapshotType, createdAt])
  @@map("uc1_roofing_measurementsnapshot")
}

