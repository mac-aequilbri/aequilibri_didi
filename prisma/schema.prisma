  alternatives String  @default("") // alternatives considered
  status      String   @default("confirmed") @db.VarChar(30)
  madeBy      String   @default("") @map("made_by") @db.VarChar(200)
  jobId       Int?     @map("job_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("uc1_roofing_decision")
}

model Uc1ActionHub {
