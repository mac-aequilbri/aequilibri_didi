model Uc1Workstream {
  id                 Int      @id @default(autoincrement())
  name               String   @db.VarChar(200)
  description        String   @default("")
  milestone          String   @default("") @db.VarChar(300)
  status             String   @default("active") @db.VarChar(20) // active | paused | complete
  loadAtSessionStart Boolean  @default(false) @map("load_at_session_start")
  lastUpdated        DateTime @updatedAt @map("last_updated")
  notes              String   @default("")

  @@map("uc1_roofing_workstream")
}

// â”€â”€ Domain extension â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Uc1ReferenceData {
