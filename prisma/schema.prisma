// Ã†quilibri â€” Prisma schema
// Ported from the Django models of uc1_roofing, uc2_didi, uc3_msme.
// Table names are pinned with @@map to the Django defaults (`<app_label>_<model>`)
// so this schema can run against the EXISTING Postgres database with zero data loss.
// Choice fields are modelled as String (Django stored them as varchar, not PG enums);
// the allowed values live in src/types as TS string-literal unions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// UC1 â€” ROOFING
// =====================================================================

model Uc1Contact {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(200)
  email     String   @default("")
  phone     String   @default("") @db.VarChar(30)
  company   String   @default("") @db.VarChar(200)
  address   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  quotes Uc1Quote[]

  @@index([createdAt])
  @@map("uc1_roofing_contact")
}

model Uc1RateCard {
  id          Int      @id @default(autoincrement())
  material    String   @db.VarChar(50)
  pitchType   String   @map("pitch_type") @db.VarChar(20)
  description String   @default("") @db.VarChar(300)
  unit        String   @default("mÂ²") @db.VarChar(20)
  rateExGst   Decimal  @map("rate_ex_gst") @db.Decimal(10, 2)
  isActive    Boolean  @default(true) @map("is_active")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([material, pitchType])
  @@map("uc1_roofing_ratecard")
}

model Uc1Quote {
  id                    Int      @id @default(autoincrement())
  refNumber             String   @unique @map("ref_number") @db.VarChar(20)
  contactId             Int?     @map("contact_id")
  propertyAddress       String   @map("property_address")
  flatAreaSqm           Decimal  @map("flat_area_sqm") @db.Decimal(10, 2)
  pitchType             String   @default("standard") @map("pitch_type") @db.VarChar(20)
  wasteFactorPct        Decimal  @default(10.0) @map("waste_factor_pct") @db.Decimal(5, 1)
  material              String   @default("colorbond") @db.VarChar(50)
  notes                 String   @default("")
  status                String   @default("draft") @db.VarChar(20)
  roofPolygonJson       String?  @map("roof_polygon_json")
  roofSectionsJson      String?  @map("roof_sections_json")
  eaveLm                Decimal  @default(0) @map("eave_lm") @db.Decimal(8, 2)
  perimeterM            Decimal  @default(0) @map("perimeter_m") @db.Decimal(8, 2)
  ridgeLm               Decimal  @default(0) @map("ridge_lm") @db.Decimal(8, 2)
  valleyLm              Decimal  @default(0) @map("valley_lm") @db.Decimal(8, 2)
  hipLm                 Decimal  @default(0) @map("hip_lm") @db.Decimal(8, 2)
  rakeLm                Decimal  @default(0) @map("rake_lm") @db.Decimal(8, 2)
  pitchDegActual        Decimal  @default(0) @map("pitch_deg_actual") @db.Decimal(5, 1)
  storeys               Int      @default(1) @db.SmallInt
  roofColour            String   @default("") @map("roof_colour") @db.VarChar(60)
  detectedEquipmentJson String?  @map("detected_equipment_json")
  pricingMechanism      String   @default("cost_plus") @map("pricing_mechanism") @db.VarChar(20)
  pricingMode           String   @default("") @map("pricing_mode") @db.VarChar(20)
  packageTier           String   @default("") @map("package_tier") @db.VarChar(20)
  markupPct             Decimal  @default(0.10) @map("markup_pct") @db.Decimal(5, 4)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  contact          Uc1Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  items            Uc1QuoteItem[]
  polygon          Uc1RoofPolygon?
  lidarAnalysis    Uc1RoofLidarAnalysis?
  solarReferrals   Uc1SolarReferral[]
  purchaseOrders   Uc1PurchaseOrder[]
  stormLeads       Uc1StormLead[]
  conditionReports Uc1RoofConditionReport[]
  executionLogs    Uc1ExecutionLog[]
  measurementSnapshots Uc1MeasurementSnapshot[]
  measurementUpdates   Uc1MeasurementUpdate[]
  quoteSnapshots       Uc1QuoteSnapshot[]

  @@index([createdAt])
  @@map("uc1_roofing_quote")
}

model Uc1QuoteItem {
  id             Int     @id @default(autoincrement())
  quoteId        Int     @map("quote_id")
  description    String  @db.VarChar(300)
  quantity       Decimal @db.Decimal(10, 2)
  unit           String  @default("mÂ²") @db.VarChar(20)
  unitPriceExGst Decimal @map("unit_price_ex_gst") @db.Decimal(10, 2)
  sortOrder      Int     @default(0) @map("sort_order") @db.SmallInt

  quote Uc1Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("uc1_roofing_quoteitem")
}

model Uc1RoofPolygon {
  id              Int      @id @default(autoincrement())
  quoteId         Int?     @unique @map("quote_id")
  coordinatesJson String   @default("[]") @map("coordinates_json")
  detectionPath   String   @default("") @map("detection_path") @db.VarChar(50)
  confidence      String   @default("") @db.VarChar(20)
  areaSqmRaw      Decimal  @default(0) @map("area_sqm_raw") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  quote Uc1Quote? @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("uc1_roofing_roofpolygon")
}

model Uc1BuildingFootprint {
  id          Int    @id @default(autoincrement())
  minLat      Float  @map("min_lat")
  maxLat      Float  @map("max_lat")
  minLon      Float  @map("min_lon")
  maxLon      Float  @map("max_lon")
  centroidLat Float  @map("centroid_lat")
  centroidLon Float  @map("centroid_lon")
  areaSqm     Float  @map("area_sqm")
  geometry    String

  @@index([minLat, maxLat])
  @@index([minLon, maxLon])
  @@map("uc1_roofing_buildingfootprint")
}

model Uc1FootprintTileCache {
  quadkey    String   @id @db.VarChar(32)
  importedAt DateTime @default(now()) @map("imported_at")

  @@map("uc1_roofing_footprinttilecache")
}

model Uc1PriceCheckLog {
  id              Int      @id @default(autoincrement())
  runAt           DateTime @default(now()) @map("run_at")
  status          String   @default("success") @db.VarChar(20)
  vendorsChecked  Int      @default(0) @map("vendors_checked") @db.SmallInt
  pricesUpdated   Int      @default(0) @map("prices_updated") @db.SmallInt
  pricesUnchanged Int      @default(0) @map("prices_unchanged") @db.SmallInt
  errors          Int      @default(0) @db.SmallInt
  summary         String   @default("")
  rawLog          String   @default("") @map("raw_log")

  @@map("uc1_roofing_pricechecklog")
}

model Uc1Vendor {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(200)
  contactName  String   @default("") @map("contact_name") @db.VarChar(200)
  contactEmail String   @default("") @map("contact_email")
  contactPhone String   @default("") @map("contact_phone") @db.VarChar(30)
  website      String   @default("")
  suburb       String   @default("") @db.VarChar(100)
  state        String   @default("QLD") @db.VarChar(10)
  notes        String   @default("")
  isPreferred  Boolean  @default(false) @map("is_preferred")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  prices         Uc1VendorMaterialPrice[]
  purchaseOrders Uc1PurchaseOrder[]

  @@map("uc1_roofing_vendor")
}

model Uc1VendorMaterialPrice {
  id             Int       @id @default(autoincrement())
  vendorId       Int       @map("vendor_id")
  material       String    @db.VarChar(50)
  itemCode       String    @default("") @map("item_code") @db.VarChar(50)
  description    String    @db.VarChar(300)
  unit           String    @default("mÂ²") @db.VarChar(20)
  unitPriceExGst Decimal   @map("unit_price_ex_gst") @db.Decimal(10, 2)
  leadDays       Int       @default(3) @map("lead_days") @db.SmallInt
  priceSourceUrl String    @default("") @map("price_source_url")
  previousPrice  Decimal?  @map("previous_price") @db.Decimal(10, 2)
  lastVerified   DateTime? @map("last_verified")
  isAvailable    Boolean   @default(true) @map("is_available")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  vendor Uc1Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, material])
  @@map("uc1_roofing_vendormaterialprice")
}

model Uc1PurchaseOrder {
  id                    Int       @id @default(autoincrement())
  poNumber              String    @unique @map("po_number") @db.VarChar(20)
  quoteId               Int?      @map("quote_id")
  vendorId              Int       @map("vendor_id")
  status                String    @default("draft") @db.VarChar(20)
  deliveryAddress       String    @default("") @map("delivery_address")
  requestedDeliveryDate DateTime? @map("requested_delivery_date") @db.Date
  notes                 String    @default("")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  quote   Uc1Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  vendor  Uc1Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  poItems Uc1PurchaseOrderItem[]

  @@map("uc1_roofing_purchaseorder")
}

model Uc1PurchaseOrderItem {
  id              Int     @id @default(autoincrement())
  purchaseOrderId Int     @map("purchase_order_id")
  description     String  @db.VarChar(300)
  itemCode        String  @default("") @map("item_code") @db.VarChar(50)
  quantity        Decimal @db.Decimal(10, 2)
  unit            String  @default("mÂ²") @db.VarChar(20)
  unitPriceExGst  Decimal @map("unit_price_ex_gst") @db.Decimal(10, 2)
  sortOrder       Int     @default(0) @map("sort_order") @db.SmallInt

  purchaseOrder Uc1PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("uc1_roofing_purchaseorderitem")
}

model Uc1RoofLidarAnalysis {
  id                    Int      @id @default(autoincrement())
  quoteId               Int      @unique @map("quote_id")
  perimeterM            Float    @default(0) @map("perimeter_m")
  gutteringLinearM      Float    @default(0) @map("guttering_linear_m")
  ridgeHeightM          Float?   @map("ridge_height_m")
  eaveHeightM           Float?   @map("eave_height_m")
  heightRangeM          Float?   @map("height_range_m")
  scaffoldingRequired   Boolean  @default(false) @map("scaffolding_required")
  scaffoldingLinearM    Float    @default(0) @map("scaffolding_linear_m")
  scaffoldingRiskLevel  String   @default("low") @map("scaffolding_risk_level") @db.VarChar(10)
  scaffoldingReason     String   @default("") @map("scaffolding_reason") @db.VarChar(200)
  structureCount        Int      @default(1) @map("structure_count") @db.SmallInt
  structuresJson        String   @default("[]") @map("structures_json")
  solarPanels           Boolean  @default(false) @map("solar_panels")
  solarHw               Boolean  @default(false) @map("solar_hw")
  lidarCoverage         String   @default("none") @map("lidar_coverage") @db.VarChar(20)
  dataSource            String   @default("") @map("data_source") @db.VarChar(50)
  analysisNotes         String   @default("") @map("analysis_notes")
  elapsedMs             Int      @default(0) @map("elapsed_ms")
  analyzedAt            DateTime @updatedAt @map("analyzed_at")

  quote Uc1Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("uc1_roofing_rooflidaranalysis")
}

model Uc1ExecutionLog {
  id         Int      @id @default(autoincrement())
  toolName   String   @map("tool_name") @db.VarChar(100)
  payload    String
  result     String
  status     String   @default("success") @db.VarChar(20)
  durationMs Int      @default(0) @map("duration_ms")
  quoteId    Int?     @map("quote_id")
  createdAt  DateTime @default(now()) @map("created_at")

  quote Uc1Quote? @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("uc1_roofing_executionlog")
}

model Uc1GutteringRate {
  id          Int      @id @default(autoincrement())
  itemType    String   @map("item_type") @db.VarChar(30)
  description String   @db.VarChar(200)
  unit        String   @default("lm") @db.VarChar(20)
  rateExGst   Decimal  @map("rate_ex_gst") @db.Decimal(10, 2)
  isActive    Boolean  @default(true) @map("is_active")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("uc1_roofing_gutteringrate")
}

model Uc1SolarPartner {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(200)
  contactName     String   @default("") @map("contact_name") @db.VarChar(200)
  contactEmail    String   @default("") @map("contact_email")
  contactPhone    String   @default("") @map("contact_phone") @db.VarChar(30)
  referralFeePct  Decimal  @default(10.0) @map("referral_fee_pct") @db.Decimal(5, 2)
  avgInstallValue Decimal  @default(10000) @map("avg_install_value") @db.Decimal(10, 2)
  isActive        Boolean  @default(true) @map("is_active")
  notes           String   @default("")
  createdAt       DateTime @default(now()) @map("created_at")

  referrals Uc1SolarReferral[]

  @@map("uc1_roofing_solarpartner")
}

model Uc1SolarReferral {
  id                    Int       @id @default(autoincrement())
  quoteId               Int       @map("quote_id")
  partnerId             Int?      @map("partner_id")
  status                String    @default("pending") @db.VarChar(20)
  solarPotentialKwh     Float     @default(0) @map("solar_potential_kwh")
  bestSectionArea       Float     @default(0) @map("best_section_area")
  bestSectionFacing     String    @default("") @map("best_section_facing") @db.VarChar(20)
  estimatedCapacityKw   Float     @default(0) @map("estimated_capacity_kw")
  estimatedInstallValue Decimal   @default(0) @map("estimated_install_value") @db.Decimal(10, 2)
  estimatedReferralFee  Decimal   @default(0) @map("estimated_referral_fee") @db.Decimal(10, 2)
  clientNotes           String    @default("") @map("client_notes")
  submittedAt           DateTime? @map("submitted_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  quote   Uc1Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  partner Uc1SolarPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@map("uc1_roofing_solarreferral")
}

model Uc1FinanceProvider {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  slug            String   @unique @db.VarChar(30)
  interestRatePct Decimal  @default(0) @map("interest_rate_pct") @db.Decimal(5, 2)
  minTermMonths   Int      @default(12) @map("min_term_months")
  maxTermMonths   Int      @default(60) @map("max_term_months")
  minAmount       Decimal  @default(1000) @map("min_amount") @db.Decimal(10, 2)
  tagline         String   @default("") @db.VarChar(200)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("uc1_roofing_financeprovider")
}

model Uc1StormEvent {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(200)
  eventType       String   @default("hail") @map("event_type") @db.VarChar(20)
  eventDate       DateTime @map("event_date") @db.Date
  severity        Int      @default(3)
  affectedSuburbs String   @map("affected_suburbs")
  state           String   @default("QLD") @db.VarChar(10)
  notes           String   @default("")
  leadsGenerated  Int      @default(0) @map("leads_generated")
  createdAt       DateTime @default(now()) @map("created_at")

  leads Uc1StormLead[]

  @@map("uc1_roofing_stormevent")
}

model Uc1StormLead {
  id             Int      @id @default(autoincrement())
  stormEventId   Int      @map("storm_event_id")
  address        String   @db.VarChar(300)
  suburb         String   @db.VarChar(100)
  state          String   @default("QLD") @db.VarChar(10)
  roofAreaSqm    Float    @default(0) @map("roof_area_sqm")
  estimatedValue Decimal  @default(0) @map("estimated_value") @db.Decimal(10, 2)
  status         String   @default("new") @db.VarChar(20)
  contactName    String   @default("") @map("contact_name") @db.VarChar(200)
  contactPhone   String   @default("") @map("contact_phone") @db.VarChar(30)
  contactEmail   String   @default("") @map("contact_email")
  notes          String   @default("")
  quoteId        Int?     @map("quote_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  stormEvent Uc1StormEvent @relation(fields: [stormEventId], references: [id], onDelete: Cascade)
  quote      Uc1Quote?     @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@map("uc1_roofing_stormlead")
}

model Uc1RoofConditionReport {
  id                 Int      @id @default(autoincrement())
  quoteId            Int      @map("quote_id")
  reportNumber       String   @unique @map("report_number") @db.VarChar(20)
  reportType         String   @default("homebuyer") @map("report_type") @db.VarChar(20)
  clientName         String   @default("") @map("client_name") @db.VarChar(200)
  clientEmail        String   @default("") @map("client_email")
  clientCompany      String   @default("") @map("client_company") @db.VarChar(200)
  conditionGrade     String   @default("B") @map("condition_grade") @db.VarChar(2)
  conditionScore     Int      @default(70) @map("condition_score")
  lifeRemainingYears Int      @default(10) @map("life_remaining_years")
  urgencyLevel       String   @default("routine") @map("urgency_level") @db.VarChar(20)
  aiAssessment       String   @default("") @map("ai_assessment")
  recommendedWorks   String   @default("") @map("recommended_works")
  inspectorName      String   @default("") @map("inspector_name") @db.VarChar(200)
  priceExGst         Decimal  @default(350) @map("price_ex_gst") @db.Decimal(8, 2)
  status             String   @default("draft") @db.VarChar(20)
  generatedAt        DateTime @default(now()) @map("generated_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  quote Uc1Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("uc1_roofing_roofconditionreport")
}

model Uc1RoofAnalysisCache {
  id            Int      @id @default(autoincrement())
  cacheKey      String   @unique @map("cache_key") @db.VarChar(128)
  address       String   @default("") @db.VarChar(255)
  lat           Float
  lng           Float
  zoom          Int
  imageHash     String   @map("image_hash") @db.VarChar(64)
  resultJson    Json     @map("result_json")
  modelVersion  String   @default("claude-opus-4-7") @map("model_version") @db.VarChar(64)
  promptVersion String   @default("v1") @map("prompt_version") @db.VarChar(32)
  createdAt     DateTime @default(now()) @map("created_at")
  lastHitAt     DateTime @updatedAt @map("last_hit_at")
  hitCount      Int      @default(0) @map("hit_count")

  @@index([address, createdAt])
  @@map("uc1_roofing_roofanalysiscache")
}

// â”€â”€ Measurement memory (UC1) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Structured roof-measurement snapshots captured during quote creation,
// the user-applied update events linked to them, and immutable quote-
// generation snapshots for later variance analysis. Ported from the
// Django MeasurementSnapshot / MeasurementUpdate / QuoteSnapshot models.

model Uc1MeasurementSnapshot {
  id              Int      @id @default(autoincrement())
  quoteId         Int?     @map("quote_id")
  snapshotType    String   @default("use_measurements") @map("snapshot_type") @db.VarChar(40)
  source          String   @default("") @db.VarChar(80)
  address         String   @default("")
  addressKey      String   @default("") @map("address_key") @db.VarChar(255)
  lat             Float?
  lng             Float?
  totalAreaM2     Decimal  @default(0) @map("total_area_m2") @db.Decimal(10, 2)
  footprintAreaM2 Decimal  @default(0) @map("footprint_area_m2") @db.Decimal(10, 2)
  pitchDeg        Decimal  @default(0) @map("pitch_deg") @db.Decimal(5, 1)
  pitchFactor     Decimal  @default(1) @map("pitch_factor") @db.Decimal(6, 3)
  eaveLm          Decimal  @default(0) @map("eave_lm") @db.Decimal(8, 2)
  perimeterM      Decimal  @default(0) @map("perimeter_m") @db.Decimal(8, 2)
  ridgeLm         Decimal  @default(0) @map("ridge_lm") @db.Decimal(8, 2)
  valleyLm        Decimal  @default(0) @map("valley_lm") @db.Decimal(8, 2)
  hipLm           Decimal  @default(0) @map("hip_lm") @db.Decimal(8, 2)
  rakeLm          Decimal  @default(0) @map("rake_lm") @db.Decimal(8, 2)
  storeys         Int      @default(1) @db.SmallInt
  material        String   @default("") @db.VarChar(80)
  roofColour      String   @default("") @map("roof_colour") @db.VarChar(80)
  sectionCount    Int      @default(0) @map("section_count") @db.SmallInt
  outlineVertices Int      @default(0) @map("outline_vertices") @db.SmallInt
  equipmentJson   String   @default("[]") @map("equipment_json")
  polygonJson     String   @default("[]") @map("polygon_json")
  sectionsJson    String   @default("[]") @map("sections_json")
  payloadJson     String   @default("{}") @map("payload_json")
  createdAt       DateTime @default(now()) @map("created_at")

  quote   Uc1Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  updates Uc1MeasurementUpdate[]
  quoteSnapshots Uc1QuoteSnapshot[]

  @@index([addressKey, createdAt])
  @@index([snapshotType, createdAt])
  @@map("uc1_roofing_measurementsnapshot")
}

model Uc1MeasurementUpdate {
  id                  Int      @id @default(autoincrement())
  snapshotId          Int      @map("snapshot_id")
  quoteId             Int?     @map("quote_id")
  updateType          String   @default("use_measurements") @map("update_type") @db.VarChar(40)
  address             String   @default("")
  addressKey          String   @default("") @map("address_key") @db.VarChar(255)
  lat                 Float?
  lng                 Float?
  previousTotalAreaM2 Decimal  @default(0) @map("previous_total_area_m2") @db.Decimal(10, 2)
  newTotalAreaM2      Decimal  @default(0) @map("new_total_area_m2") @db.Decimal(10, 2)
  deltaAreaM2         Decimal  @default(0) @map("delta_area_m2") @db.Decimal(10, 2)
  changedFieldsJson   String   @default("[]") @map("changed_fields_json")
  payloadJson         String   @default("{}") @map("payload_json")
  createdAt           DateTime @default(now()) @map("created_at")

  snapshot Uc1MeasurementSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  quote    Uc1Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([addressKey, createdAt])
  @@index([updateType, createdAt])
  @@map("uc1_roofing_measurementupdate")
}

model Uc1QuoteSnapshot {
  id                   Int      @id @default(autoincrement())
  quoteId              Int      @map("quote_id")
  measurementSnapshotId Int?    @map("measurement_snapshot_id")
  address              String   @default("")
  addressKey           String   @default("") @map("address_key") @db.VarChar(255)
  pricingMechanism     String   @default("") @map("pricing_mechanism") @db.VarChar(30)
  pricingMode          String   @default("") @map("pricing_mode") @db.VarChar(30)
  packageTier          String   @default("") @map("package_tier") @db.VarChar(30)
  roofType             String   @default("") @map("roof_type") @db.VarChar(30)
  roofAreaM2           Decimal  @default(0) @map("roof_area_m2") @db.Decimal(10, 2)
  eaveLm               Decimal  @default(0) @map("eave_lm") @db.Decimal(8, 2)
  markupPct            Decimal  @default(0) @map("markup_pct") @db.Decimal(6, 4)
  subtotalExGst        Decimal  @default(0) @map("subtotal_ex_gst") @db.Decimal(12, 2)
  gstAmount            Decimal  @default(0) @map("gst_amount") @db.Decimal(12, 2)
  totalIncGst          Decimal  @default(0) @map("total_inc_gst") @db.Decimal(12, 2)
  inputsJson           String   @default("{}") @map("inputs_json")
  lineItemsJson        String   @default("[]") @map("line_items_json")
  pricingBreakdownJson String   @default("{}") @map("pricing_breakdown_json")
  createdAt            DateTime @default(now()) @map("created_at")

  quote               Uc1Quote                @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  measurementSnapshot Uc1MeasurementSnapshot? @relation(fields: [measurementSnapshotId], references: [id], onDelete: SetNull)

  @@index([addressKey, createdAt])
  @@index([quoteId, createdAt])
  @@map("uc1_roofing_quotesnapshot")
}

// â”€â”€ Memory architecture / learning loop (UC1) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Episodic: Job + Correction. Hypothesis â†’ LearningRule promotion.
// Contextual Intelligence snapshot. See aequilibri Memory Architecture doc.

model Uc1Job {
  id                    Int       @id @default(autoincrement())
  quoteId               Int?      @map("quote_id")
  address               String    @default("")
  estimatorId           Int?      @map("estimator_id")
  sessionOpenAt         DateTime? @map("session_open_at")
  sessionCloseAt        DateTime? @map("session_close_at")
  // AI estimates (set at session close)
  estimatedAreaM2       Float     @default(0) @map("estimated_area_m2")
  estimatedValleyLm     Float     @default(0) @map("estimated_valley_lm")
  estimatedRidgeLm      Float     @default(0) @map("estimated_ridge_lm")
  estimatedEaveLm       Float     @default(0) @map("estimated_eave_lm")
  estimatedHipLm        Float     @default(0) @map("estimated_hip_lm")
  estimatedTotal        Decimal   @default(0) @map("estimated_total") @db.Decimal(12, 2)
  // Actual outcomes (set when job invoiced)
  actualAreaM2          Float?    @map("actual_area_m2")
  actualValleyLm        Float?    @map("actual_valley_lm")
  actualRidgeLm         Float?    @map("actual_ridge_lm")
  actualEaveLm          Float?    @map("actual_eave_lm")
  actualHipLm           Float?    @map("actual_hip_lm")
  actualTotal           Decimal?  @map("actual_total") @db.Decimal(12, 2)
  // Derived
  variancePctArea       Float?    @map("variance_pct_area")
  variancePctQuote      Float?    @map("variance_pct_quote")
  learningRuleCandidate Boolean   @default(false) @map("learning_rule_candidate")
  rulesAppliedJson      String    @default("[]") @map("rules_applied_json") // codes of rules applied
  status                String    @default("open") @db.VarChar(20) // open | estimated | completed | invoiced
  notes                 String    @default("")
  createdAt             DateTime  @default(now()) @map("created_at")
  completedAt           DateTime? @map("completed_at")

  estimator   Uc1TeamMember? @relation(fields: [estimatorId], references: [id], onDelete: SetNull)
  corrections Uc1Correction[]

  @@index([createdAt])
  @@map("uc1_roofing_job")
}

model Uc1Correction {
  id           Int       @id @default(autoincrement())
  jobId        Int?      @map("job_id")
  quoteId      Int?      @map("quote_id")
  address      String    @default("")
  suburb       String    @default("") @db.VarChar(120)
  lat          Float?
  lng          Float?
  dimension    String    @db.VarChar(40) // roof_area | valley_lm | ridge_lm | pitch | contingency ...
  aiValue      Float     @default(0) @map("ai_value")
  humanValue   Float     @default(0) @map("human_value")
  variancePct  Float     @default(0) @map("variance_pct")
  rootCause    String    @default("") @map("root_cause") // REQUIRED â€” never blank
  estimatorId  Int?      @map("estimator_id")
  hypothesisId Int?      @map("hypothesis_id")
  ruleId       Int?      @map("rule_id") // set if this correction led to a rule
  createdAt    DateTime  @default(now()) @map("created_at")

  job        Uc1Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  estimator  Uc1TeamMember?  @relation(fields: [estimatorId], references: [id], onDelete: SetNull)
  hypothesis Uc1Hypothesis?  @relation(fields: [hypothesisId], references: [id], onDelete: SetNull)

  @@index([dimension, createdAt])
  @@map("uc1_roofing_correction")
}

model Uc1Hypothesis {
  id               Int      @id @default(autoincrement())
  description      String
  dimension        String   @db.VarChar(40)
  rootCausePattern String   @default("") @map("root_cause_pattern")
  triggerCondition String   @default("") @map("trigger_condition")
  sampleCount      Int      @default(0) @map("sample_count")
  avgVariancePct   Float    @default(0) @map("avg_variance_pct")
  confidence       Int      @default(0) // 0-100
  status           String   @default("pending") @db.VarChar(20) // pending | active | validated | rejected | promoted
  promoteToRule    Boolean  @default(false) @map("promote_to_rule")
  createdAt        DateTime @default(now()) @map("created_at")
  reviewedAt       DateTime? @map("reviewed_at")

  corrections Uc1Correction[]
  rules       Uc1LearningRule[]

  @@map("uc1_roofing_hypothesis")
}

model Uc1LearningRule {
  id               Int       @id @default(autoincrement())
  ruleCode         String    @unique @map("rule_code") @db.VarChar(20)
  description      String
  category         String    @default("measurement") @db.VarChar(30) // measurement | pricing | scope | regional | equipment
  dimension        String    @db.VarChar(40)
  triggerCondition String    @default("") @map("trigger_condition")
  adjustment       String    @default("{}") // JSON: { type, value }
  priority         Int       @default(3)
  confidence       Int       @default(72)
  timesTriggered   Int       @default(0) @map("times_triggered")
  isActive         Boolean   @default(true) @map("is_active")
  autoApply        Boolean   @default(false) @map("auto_apply")
  sourceId         Int?      @map("source_id")
  taughtById       Int?      @map("taught_by_id")
  dateActivated    DateTime? @map("date_activated")
  notes            String    @default("")
  createdAt        DateTime  @default(now()) @map("created_at")

  source    Uc1Hypothesis?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  taughtBy  Uc1TeamMember?  @relation(fields: [taughtById], references: [id], onDelete: SetNull)

  @@map("uc1_roofing_learningrule")
}

model Uc1IntelligenceSnapshot {
  id                   Int      @id @default(autoincrement())
  capturedAt           DateTime @default(now()) @map("captured_at")
  totalJobs            Int      @default(0) @map("total_jobs")
  completedJobs        Int      @default(0) @map("completed_jobs")
  accuracyRatePct      Float    @default(0) @map("accuracy_rate_pct")
  activeRules          Int      @default(0) @map("active_rules")
  autoApplyRules       Int      @default(0) @map("auto_apply_rules")
  avgConfidence        Float    @default(0) @map("avg_confidence")
  confidenceTrajectory String   @default("stable") @map("confidence_trajectory") @db.VarChar(20) // improving | stable | degrading
  topRulesJson         String   @default("[]") @map("top_rules_json")
  gapsJson             String   @default("[]") @map("gaps_json")
  notes                String   @default("")

  @@map("uc1_roofing_intelligencesnapshot")
}

// â”€â”€ Customer configuration (Port City Roofing) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

